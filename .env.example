# IHC API Configuration
# Get your API key from your IHC account dashboard
IHC_API_URL=https://api.ihc-attribution.com/v1/compute_ihc
IHC_API_KEY=your_api_key_here
IHC_CONV_TYPE_ID=default
# Optional JSON dictionary passed as redistribution_parameter in API body
# IHC_REDISTRIBUTION_PARAMETER={"initializer":{"direction":"earlier_sessions_only","receive_threshold":0,"redistribution_channel_labels":["Direct"]}}
# Set to 0 to process all available journeys
IHC_MAX_JOURNEYS_PER_RUN=100
IHC_CHUNK_SIZE=200
IHC_MAX_SESSIONS_PER_REQUEST=200
IHC_REQUEST_TIMEOUT_SECONDS=30

# Database Configuration
ATTRIBUTION_DB_PATH=challenge.db
ATTRIBUTION_SCHEMA_SQL_PATH=challenge_db_create.sql
ATTRIBUTION_OUTPUT_CSV=channel_reporting.csv
